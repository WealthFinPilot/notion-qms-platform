    {
      "parameters": {
        "jsCode": "// Récupérer tous les items d'entrée\nconst items = $input.all();\n\n// Liste des statuts autorisés\nconst statutsAutorises = [\"Bloqué\", \"Commandé\", \"En Cours\"];\n\n// Traiter chaque item\nconst outputItems = items.map(item => {\n  // Récupérer le Statut Demande actuel\n  let statutDemande = $('Edit New Statut').first().json[\"Statut Demande\"];\n  \n  // Vérifier si le statut est dans la liste autorisée\n  let nouveauStatut = \"\";\n  \n  if (statutsAutorises.includes(statutDemande)) {\n    // Garder le statut s'il est autorisé\n    nouveauStatut = statutDemande;\n  } else {\n    // Vider le statut s'il n'est pas autorisé\n    nouveauStatut = \"\";\n  }\n  \n  // Retourner l'item avec le statut filtré\n  return {\n    json: {\n      ...item.json,\n      \"Statut Demande\": nouveauStatut\n    }\n  };\n});\n\nreturn outputItems;"
      },
