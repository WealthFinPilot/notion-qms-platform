    {
      "parameters": {
        "jsCode": "// Récupérer l'item d'entrée\nconst inputItem = $input.first().json;\n\n// Vérifier que le champ \"Demandes\" existe\nif (!inputItem.Demandes) {\n  return [{ json: { message: \"Champ 'Demandes' non trouvé\" } }];\n}\n\n// Splitter la string par \", \" pour récupérer les IDs individuels\nconst ids = inputItem.Demandes.split(\", \");\n\n// Créer un item pour chaque ID\nconst outputItems = ids.map((id, index) => {\n  return {\n    json: {\n      // Garder toutes les données originales sauf \"Demandes\"\n      ...inputItem,\n      // Remplacer \"Demandes\" par l'ID individuel\n      Demandes: id.trim()\n    }\n  };\n});\n\nreturn outputItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
