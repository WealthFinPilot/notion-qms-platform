    {
      "parameters": {
        "jsCode": "// Récupérer l'item d'entrée\nconst item = $input.first().json;\n\n// Extraire le Statut PO (adapter selon ta structure de données)\nlet statutPO = null;\n\n\n// Si c'est dans properties (structure Notion)\nif (item.properties && item.properties[\"Statut PO\"] && item.properties[\"Statut PO\"].status) {\n  statutPO = item.properties[\"Statut PO\"].status.name;\n}\n// Si c'est directement accessible\nelse if (item[\"Statut PO\"]) {\n  statutPO = item[\"Statut PO\"];\n}\n\n// Mapping des statuts selon tes règles\nlet statutDemande = \"Non défini\";\nlet FinalDemande = \"Non défini\";\n\n\nswitch (statutPO) {\n  case \"Commande Partiel\":\n  case \"Commandé\":\n    statutDemande = \"Commandé\";\n    break;\n  \n  case \"Bloqué\":\n    statutDemande = \"Bloqué\";\n    break;\n  \n  case \"Annulé\":\n    statutDemande = \"Annulé\";\n    FinalDemande = \"Fermeture\";\n    break;\n  \n  case \"Refusé\":\n    statutDemande = \"Refusé\";\n    FinalDemande = \"Fermeture\";\n    break;\n  \n  case \"⚠️Non-Conforme⚠️\":\n    statutDemande = \"⚠️Non-Conforme⚠️\";\n    FinalDemande = \"Fermeture\";\n    break;\n  \n  case \"Clôturé\":\n    statutDemande = \"Livré\";\n    FinalDemande = \"Fermeture\";\n    break;\n  \n  case \"À traiter\":\n    statutDemande = \"En cours\";\n    break;\n  \n  default:\n    statutDemande = \"Non défini\";\n    FinalDemande = \"Non défini\";\n}\n\n// Retourner l'item avec le nouveau statut\nreturn [{\n  json: {\n    ...item,\n    \"Statut Demande\": statutDemande,\n    \"Final Demande\" : FinalDemande,\n    // Debug info\n    \"Statut PO Original\": statutPO\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -976,
        16
